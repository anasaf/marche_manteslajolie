{% extends 'base.html.twig' %}

{% block title %}Plan 3D interactif{% endblock %}

{% block body %}
    <div class="container my-5 text-center">
        <h1>Plan interactif en 3D</h1>
        <p>Cliquez sur un magasin pour voir ses détails</p>
    </div>

    <div id="plan3d" style="width:100%; height:600px; cursor: pointer;"></div>

    <!-- Modal Bootstrap -->
    <div class="modal fade" id="magasinModal" tabindex="-1" aria-labelledby="magasinModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="magasinModalLabel">Nom du magasin</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body text-center">
                    <img id="magasinImage" src="" alt="Logo magasin" class="img-fluid rounded mb-3" style="max-height:200px;">
                    <p id="magasinDescription">Description du magasin...</p>
                </div>
                <div class="modal-footer">
                    <a id="magasinLink" href="#" class="btn btn-primary">Voir la fiche</a>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts Three.js r125 UMD et Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/three@0.125.2/build/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.125.2/examples/js/controls/OrbitControls.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // --- Scène et caméra ---
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0xbfd1e5);

        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / 600, 0.1, 1000);
        camera.position.set(5, 5, 10);

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, 600);
        document.getElementById('plan3d').appendChild(renderer.domElement);

        // Contrôles (fonctionne sur r125 UMD)
        const controls = new THREE.OrbitControls(camera, renderer.domElement);

        // Lumières
        scene.add(new THREE.AmbientLight(0x404040, 2));
        const directionalLight = new THREE.DirectionalLight(0xffffff, 1);
        directionalLight.position.set(5, 10, 7).normalize();
        scene.add(directionalLight);

        // Sol (verdure)
        const groundGeometry = new THREE.PlaneGeometry(20, 20);
        const groundMaterial = new THREE.MeshLambertMaterial({ color: 0x228B22 });
        const ground = new THREE.Mesh(groundGeometry, groundMaterial);
        ground.rotation.x = -Math.PI / 2;
        scene.add(ground);

        // Route
        const roadGeometry = new THREE.RingGeometry(10, 10.5, 64);
        const roadMaterial = new THREE.MeshLambertMaterial({ color: 0x333333, side: THREE.DoubleSide });
        const road = new THREE.Mesh(roadGeometry, roadMaterial);
        road.rotation.x = -Math.PI / 2;
        scene.add(road);

        // Magasins
        const magasins = [];
        const magasinInfos = [
            { name: "Ali la mode vetements femme", desc: "Boutique de mode tendance.", image: "https://picsum.photos/300/200?1", url: "{{ path('commercants', {categorie: 'mode'}) }}" },
            { name: "Mohamed linge de maison", desc: "Vêtements accessibles pour tous.", image: "https://picsum.photos/300/200?2", url: "{{ path('commercants', {categorie: 'mode'}) }}" },
            { name: "Berbere fruit et legumes", desc: "Supermarché et alimentation générale.", image: "https://picsum.photos/300/200?3", url: "{{ path('commercants', {categorie: 'alimentaire'}) }}" },
            { name: "Nanas coffee", desc: "Café, boissons et gourmandises.", image: "https://picsum.photos/300/200?4", url: "{{ path('commercants', {categorie: 'alimentaire'}) }}" }
        ];

        const magasinGeometry = new THREE.BoxGeometry(2, 1, 2);
        const colors = [0xff6666, 0x66ccff, 0x99ff99, 0xffcc66];

        for (let i = 0; i < magasinInfos.length; i++) {
            const material = new THREE.MeshLambertMaterial({ color: colors[i] });
            const cube = new THREE.Mesh(magasinGeometry, material);
            cube.position.set((i % 2) * 3 - 1.5, 0.5, Math.floor(i / 2) * 3 - 1.5);
            cube.userData = magasinInfos[i];
            scene.add(cube);
            magasins.push(cube);
        }

        // Raycaster pour clic
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();

        function onMouseClick(event) {
            const rect = renderer.domElement.getBoundingClientRect();
            mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
            mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(magasins);

            if (intersects.length > 0) {
                const magasin = intersects[0].object.userData;

                // Remplir modal
                document.getElementById('magasinModalLabel').innerText = magasin.name;
                document.getElementById('magasinImage').src = magasin.image;
                document.getElementById('magasinDescription').innerText = magasin.desc;
                document.getElementById('magasinLink').href = magasin.url;

                // Ouvrir modal
                const modal = new bootstrap.Modal(document.getElementById('magasinModal'));
                modal.show();
            }
        }

        window.addEventListener('click', onMouseClick);

        // Animation
        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }
        animate();

        // Responsive
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / 600;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, 600);
        });
    </script>
{% endblock %}
