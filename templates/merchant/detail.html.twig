{% extends 'base.html.twig' %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/sephora_products.css') }}">
{% endblock %}

{% block title %}{{ merchant.name }} - Products{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gradient-to-b from-pink-50 via-purple-50 to-blue-50 p-6">
{% set current_category ="" %}
{% set current_search ="" %}
{% set current_sort ="" %}
        <!-- Merchant Header -->
        <section class="max-w-6xl mx-auto mb-10">
            <div class="bg-white rounded-3xl shadow-lg p-8 flex items-center gap-6">
                <img src="{{ merchant.logoUrl ?? '/images/merchant-placeholder.png' }}"
                     alt="{{ merchant.name }}"
                     class="w-32 h-32 rounded-full object-cover border-4 border-indigo-400 shadow-md">
                <div>
                    <h1 class="text-4xl font-extrabold text-gray-800">{{ merchant.name }}</h1>
                    <p class="mt-2 text-gray-600">{{ merchant.category }}</p>
                    <p class="mt-4 text-gray-500 max-w-lg">{{ merchant.description }}</p>
                </div>
            </div>
        </section>

        <!-- Filter & Sort -->
        <section class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
            <form method="get" action="{{ path('product_list') }}" class="flex gap-3 flex-wrap">
                <select name="category" class="border border-gray-300 bg-white text-gray-700 py-2 px-3 rounded-xl shadow-sm focus:ring-2 focus:ring-indigo-400">
                    <option value="">All Categories</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {% if cat.id == current_category %}selected{% endif %}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
                <input type="text" name="search" placeholder="Search…"
                       value="{{ current_search }}"
                       class="border border-gray-300 bg-white text-gray-700 py-2 px-3 rounded-xl shadow-sm focus:ring-2 focus:ring-indigo-400">
                <button type="submit" class="bg-indigo-600 text-white py-2 px-4 rounded-xl hover:bg-indigo-700 transition">Filter</button>
            </form>

            <div class="flex items-center gap-2">
                <label for="sort" class="text-gray-700 font-medium">Sort by:</label>
                <select id="sort" name="sort" form="sortForm"
                        class="border border-gray-300 bg-white text-gray-700 py-2 px-3 rounded-xl shadow-sm focus:ring-2 focus:ring-indigo-400">
                    <option value="relevance" {% if current_sort == 'relevance' %}selected{% endif %}>Relevance</option>
                    <option value="price_asc" {% if current_sort == 'price_asc' %}selected{% endif %}>Price: Low to High</option>
                    <option value="price_desc" {% if current_sort == 'price_desc' %}selected{% endif %}>Price: High to Low</option>
                    <option value="newest" {% if current_sort == 'newest' %}selected{% endif %}>Newest</option>
                    <option value="best_sellers" {% if current_sort == 'best_sellers' %}selected{% endif %}>Best Sellers</option>
                </select>
                <form id="sortForm" method="get" action="{{ path('product_list') }}" class="hidden">
                    <input type="hidden" name="category" value="{{ current_category }}">
                    <input type="hidden" name="search" value="{{ current_search }}">
                    <input type="hidden" name="sort" value="" id="sortInput">
                </form>
            </div>
        </section>

        <!-- Products Grid -->
        <section class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {% for product in products %}
                <div class="bg-white rounded-3xl shadow-lg hover:shadow-2xl transition transform hover:-translate-y-1 overflow-hidden">
                    <div class="relative w-full h-64">
                        <img src="{{ product.imageFile ?? '/images/product-placeholder.png' }}"
                             alt="{{ product.name }}"
                             class="w-full h-full object-cover">
                        {% if product.isNew ?? false %}
                            <span class="absolute top-3 left-3 bg-green-500 text-white text-xs font-semibold px-2 py-1 rounded-full">NEW</span>
                        {% endif %}
                    </div>
                    <div class="p-4 flex flex-col justify-between h-40">
                        <div>
                            <h3 class="text-lg font-semibold text-gray-800 truncate">{{ product.name }}</h3>
                            <p class="text-gray-500 mt-1 line-clamp-2">{{ product.description }}</p>
                        </div>
                        <div class="mt-4 flex justify-between items-center">
                            <span class="text-indigo-600 font-bold text-lg">{{ product.price }} €</span>
                            <form action="{{ path('cart_add', {id: product.id}) }}" method="post">
                                <button class="bg-green-500 text-white px-4 py-2 rounded-xl hover:bg-green-600 shadow transition">
                                    Add
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="col-span-4 text-center text-gray-500 mt-6">No products found.</p>
            {% endfor %}
        </section>

        <!-- Pagination -->
        <div class="max-w-6xl mx-auto mt-8">
            {{ knp_pagination_render(products) }}
        </div>

    </div>

{% endblock %}

{% block javascripts %}
    <script>
        // Sort auto-submit
        document.getElementById('sort').addEventListener('change', function() {
            document.getElementById('sortInput').value = this.value;
            document.getElementById('sortForm').submit();
        });
    </script>
{% endblock %}
