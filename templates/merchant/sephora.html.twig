{% extends 'base.html.twig' %}

{% block title %}{{ merchant.name }} - Products{% endblock %}

{% block stylesheets %}
    {{ encore_entry_link_tags('sephora') }}
{% endblock %}

{% block body %}
    <div class="container mx-auto p-6">
        {{ asset('css/sephora_products.css') }}

        <!-- Merchant Header -->
        <div class="merchant-header bg-white p-6 rounded-2xl shadow-lg flex gap-6 mb-8 items-center">
            <img src="{{ merchant.logoUrl ?? '/images/merchant-placeholder.png' }}" alt="{{ merchant.name }}" class="w-32 h-32 rounded-full object-cover border-4 border-pink-500">
            <div>
                <h1 class="text-3xl font-bold">{{ merchant.name }}</h1>
                <p class="text-gray-500">{{ merchant.category }}</p>
                <p class="mt-2 text-gray-400">{{ merchant.description }}</p>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="products-grid">
            {% for product in products %}
                <div class="product-card relative">

                    <!-- Product Image -->
                    <div class="product-image">
                        <img src="{{ product.imageFile ?? '/images/product-placeholder.png' }}" alt="{{ product.name }}">
                        {% if product.isNew ?? false %}
                            <span class="product-badge">NEW</span>
                        {% endif %}

                        <!-- Hover Overlay -->
                        <div class="product-overlay">
                            <form action="{{ path('cart_add', {id: product.id}) }}" method="post">
                                <button type="submit">Add to Cart</button>
                            </form>
                            <button onclick="alert('Quick view not implemented')">Quick View</button>
                        </div>
                    </div>

                    <!-- Product Info -->
                    <div class="product-info">
                        <h3>{{ product.name }}</h3>
                        <p>{{ product.description }}</p>
                        <div class="product-price-rating">
                            <span class="price">{{ product.price }} €</span>
                            <span class="product-rating">
                        {% for i in 1..5 %}
                            {% if i <= product.rating|default(0) %}
                                ★
                            {% else %}
                                ☆
                            {% endif %}
                        {% endfor %}
                    </span>
                        </div>
                    </div>
                </div>
            {% else %}
                <p>No products available.</p>
            {% endfor %}
        </div>

        <!-- Pagination -->
        <div class="mt-8">
            {{ knp_pagination_render(products) }}
        </div>

    </div>
{% endblock %}
