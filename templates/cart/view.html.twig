{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}
<h1>Mon panier</h1>
<ul>
  {% for line in cart.lines %}
    <li>{{ line.productName }} x {{ line.quantity }} — {{ line.unitPrice }} €</li>
  {% else %}
    <li>Panier vide</li>
  {% endfor %}
</ul>

<p>Total : {{ cart.total }} €</p>

<a href="{{ path('acme_checkout', { token: cart.token }) }}">Passer au paiement</a>
{% endblock %}
