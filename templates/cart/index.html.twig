{% extends 'base.html.twig' %}

{% block title %}Your Cart{% endblock %}

{% block body %}
    <div class="max-w-3xl mx-auto mt-8 bg-white p-6 shadow rounded-2xl">
        <h1 class="text-2xl font-bold mb-4">Your Cart</h1>

        {% if items is not empty %}
            <table class="w-full border-collapse">
                <thead>
                <tr class="border-b text-left">
                    <th class="p-2">Product</th>
                    <th class="p-2 text-center">Quantity</th>
                    <th class="p-2 text-right">Price</th>
                    <th class="p-2 text-center">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for item in items %}
                    <tr class="border-b">
                        <td class="p-2">{{ item.product.name }}</td>
                        <td class="p-2 text-center">{{ item.quantity }}</td>
                        <td class="p-2 text-right">{{ item.product.price * item.quantity }} €</td>
                        <td class="p-2 text-center space-x-1">
                            <a href="{{ path('cart_add', {id: item.product.id}) }}" class="px-2 py-1 bg-green-600 text-white rounded">+</a>
                            <a href="{{ path('cart_decrement', {id: item.product.id}) }}" class="px-2 py-1 bg-yellow-500 text-white rounded">-</a>
                            <a href="{{ path('cart_remove', {id: item.product.id}) }}" class="px-2 py-1 bg-red-600 text-white rounded">Remove</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            <div class="mt-6 flex justify-between items-center">
                <span class="text-xl font-bold">Total: {{ total }} €</span>
                <a href="{{ path('checkout') }}" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                    Checkout
                </a>
            </div>
        {% else %}
            <p class="text-gray-600">Your cart is empty.</p>
        {% endif %}
    </div>
{% endblock %}
