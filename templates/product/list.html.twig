{% extends 'base.html.twig' %}

{% block title %}Product List{% endblock %}

{% block body %}
    <div class="min-h-screen bg-gradient-to-br from-pink-50 via-purple-50 to-blue-50 p-6">

        <!-- Filter & Sort Bar -->
        <div class="max-w-6xl mx-auto mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <!-- Filters -->
            <form method="get" action="{{ path('product_list') }}" class="flex gap-3 flex-wrap">
                <select name="category" class="border border-gray-300 bg-white text-gray-700 py-2 px-3 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
                    <option value="">All Categories</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {% if cat.id == current_category %}selected{% endif %}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
                <input type="text" name="search" placeholder="Search products…"
                       value="{{ current_search }}"
                       class="border border-gray-300 bg-white text-gray-700 py-2 px-3 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                <button type="submit" class="bg-indigo-500 text-white py-2 px-4 rounded-xl shadow hover:bg-indigo-600 transition">Filter</button>
            </form>

            <!-- Sort -->
            <div>
                <label for="sort" class="mr-2 text-gray-700">Sort by:</label>
                <select id="sort" name="sort" form="sortForm"
                        class="border border-gray-300 bg-white text-gray-700 py-2 px-3 rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
                    <option value="relevance" {% if current_sort == 'relevance' %}selected{% endif %}>Relevance</option>
                    <option value="price_asc" {% if current_sort == 'price_asc' %}selected{% endif %}>Price: Low to High</option>
                    <option value="price_desc" {% if current_sort == 'price_desc' %}selected{% endif %}>Price: High to Low</option>
                    <option value="newest" {% if current_sort == 'newest' %}selected{% endif %}>Newest</option>
                    <option value="best_sellers" {% if current_sort == 'best_sellers' %}selected{% endif %}>Best Sellers</option>
                </select>
                <form id="sortForm" method="get" action="{{ path('product_list') }}" class="hidden">
                    <input type="hidden" name="category" value="{{ current_category }}">
                    <input type="hidden" name="search" value="{{ current_search }}">
                    <input type="hidden" name="sort" value="" id="sortInput">
                </form>
            </div>
        </div>

        <!-- Product Table -->
        <div class="max-w-6xl mx-auto overflow-x-auto bg-white shadow-lg rounded-2xl">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-indigo-100/60">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Product</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Category</th>
                    <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Price</th>
                    <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Rating</th>
                    <th class="px-6 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Cart</th>
                </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-100">
                {% for product in products %}
                    <tr class="hover:bg-indigo-50 transition">
                        <td class="px-6 py-4 flex items-center gap-4">
                            <div class="w-16 h-16 flex-shrink-0 rounded-lg overflow-hidden shadow">
                                <img src="{{ asset('uploads/products/' ~ product.imageName) }}"
                                     alt="{{ product.name }}"
                                     class="w-full h-full object-cover">
                            </div>
                            <div>
                                <div class="font-medium text-gray-800">{{ product.name }}</div>
                                <div class="text-sm text-gray-500 truncate max-w-xs">{{ product.description }}</div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-gray-600">{{ product.category.name }}</td>
                        <td class="px-6 py-4 text-center text-indigo-600 font-semibold">{{ product.price }} €</td>
                        <td class="px-6 py-4 text-center text-yellow-500">
                            {% if product.rating is defined %}
                                ⭐ {{ product.rating }}/5
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-center">
                            <form action="{{ path('cart_add', {id: product.id}) }}" method="post">
                                <button type="submit" class="bg-green-500 text-white py-1.5 px-4 rounded-xl shadow hover:bg-green-600 transition">
                                    Add
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-gray-500">No products found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="max-w-6xl mx-auto mt-6">
            {{ knp_pagination_render(products) }}
        </div>

    </div>
{% endblock %}

{% block javascripts %}
    <script>
        // Script for auto-submit on sort change
        document.getElementById('sort').addEventListener('change', function() {
            document.getElementById('sortInput').value = this.value;
            document.getElementById('sortForm').submit();
        });
    </script>
{% endblock %}
